{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "personal-dashboard",
  "version": "0.1.0",
  "identifier": "com.projectdashboard.app",
  "build": {
  "frontendDist": "../DOES_NOT_EXIST"
},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "personal-dashboard",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
